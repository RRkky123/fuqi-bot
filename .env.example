# ============================================================
# 福氣天天領 — 環境變數設定範本
# 複製為 .env 並填入實際值
# ============================================================

# === LINE Bot ===
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# === LIFF ===
LIFF_ID=your_liff_id_here
LIFF_BASE_URL=https://your-domain.com

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fuqi_bot
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/fuqi_bot

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === AWS (S3 + Rekognition) ===
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=fuqi-bot-images
CDN_BASE_URL=https://your-cdn-domain.com

# === 天氣 API ===
CWB_API_KEY=your_central_weather_bureau_api_key
OPENWEATHERMAP_API_KEY=your_openweathermap_key   # 備援

# === AI 合成 API ===
REPLICATE_API_TOKEN=your_replicate_token
# 或 FaceSwap SaaS
REMAKER_API_KEY=your_remaker_api_key

# === 藍新金流 ===
NEWEBPAY_MERCHANT_ID=your_merchant_id
NEWEBPAY_HASH_KEY=your_hash_key
NEWEBPAY_HASH_IV=your_hash_iv
NEWEBPAY_API_URL=https://ccore.newebpay.com/MPG/mpg_gateway  # 測試環境
# 正式環境: https://core.newebpay.com/MPG/mpg_gateway

# === App 設定 ===
APP_ENV=development   # development / production
APP_SECRET_KEY=your_random_secret_key_here
BASE_URL=https://your-domain.com

# === 業務參數 ===
DAILY_FREE_LIMIT=1              # 每日免費張數
CREDIT_PRICE_SINGLE=10         # 單張售價（NT$）
CREDIT_PRICE_BUNDLE_10=80      # 10張套組售價（NT$）
CREDIT_EXPIRY_DAYS=180         # 合成券有效天數
MAX_DAILY_SYNTHESIS=500        # 每日 AI 合成上限（成本控制）
MAX_DAILY_REFERRALS=10         # 每日最大邀請數（防刷）
SYNTHESIS_TIMEOUT_SEC=90       # AI 合成逾時秒數
